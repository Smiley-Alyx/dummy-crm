:root {
  --text: #6b6375;
  --text-h: #08060d;
  --bg: #fff;
  --border: #e5e4e7;
  --code-bg: #f4f3ec;
  --accent: #aa3bff;
  --accent-bg: rgba(170, 59, 255, 0.1);
  --accent-border: rgba(170, 59, 255, 0.5);
  --social-bg: rgba(244, 243, 236, 0.5);
  --shadow:
    rgba(0, 0, 0, 0.1) 0 10px 15px -3px, rgba(0, 0, 0, 0.05) 0 4px 6px -2px;

  --sans: system-ui, 'Segoe UI', Roboto, sans-serif;
  --heading: system-ui, 'Segoe UI', Roboto, sans-serif;
  --mono: ui-monospace, Consolas, monospace;

  font: 18px/145% var(--sans);
  letter-spacing: 0.18px;
  color-scheme: light dark;
  color: var(--text);
  background: var(--bg);
  font-synthesis: none;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;

  @media (max-width: 1024px) {
    font-size: 16px;
  }
}

@media (prefers-color-scheme: dark) {
  :root {
    --text: #9ca3af;
    --text-h: #f3f4f6;
    --bg: #16171d;
    --border: #2e303a;
    --code-bg: #1f2028;
    --accent: #c084fc;
    --accent-bg: rgba(192, 132, 252, 0.15);
    --accent-border: rgba(192, 132, 252, 0.5);
    --social-bg: rgba(47, 48, 58, 0.5);
    --shadow:
      rgba(0, 0, 0, 0.4) 0 10px 15px -3px, rgba(0, 0, 0, 0.25) 0 4px 6px -2px;
  }

  #social .button-icon {
    filter: invert(1) brightness(2);
  }
}

body {
  margin: 0;
}

h1,
h2 {
  font-family: var(--heading);
  font-weight: 500;
  color: var(--text-h);
}

h1 {
  font-size: 56px;
  letter-spacing: -1.68px;
  margin: 32px 0;
  @media (max-width: 1024px) {
    font-size: 36px;
    margin: 20px 0;
  }
}

h2 {
  font-size: 24px;
  line-height: 118%;
  letter-spacing: -0.24px;
  margin: 0 0 8px;
  @media (max-width: 1024px) {
    font-size: 20px;
  }
}

p {
  margin: 0;
}

code,
.counter {
  font-family: var(--mono);
  display: inline-flex;
  border-radius: 4px;
  color: var(--text-h);
}

code {
  font-size: 15px;
  line-height: 135%;
  padding: 4px 8px;
  background: var(--code-bg);
}

.counter {
  font-size: 16px;
  padding: 5px 10px;
  border-radius: 5px;
  color: var(--accent);
  background: var(--accent-bg);
  border: 2px solid transparent;
  transition: border-color 0.3s;
  margin-bottom: 24px;

  &:hover {
    border-color: var(--accent-border);
  }
  &:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
}

.hero {
  position: relative;

  .base,
  .framework,
  .vite {
    inset-inline: 0;
    margin: 0 auto;
  }

  .base {
    width: 170px;
    position: relative;
    z-index: 0;
  }

  .framework,
  .vite {
    position: absolute;
  }

  .framework {
    z-index: 1;
    top: 34px;
    height: 28px;
    transform: perspective(2000px) rotateZ(300deg) rotateX(44deg) rotateY(39deg)
      scale(1.4);
  }

  .vite {
    z-index: 0;
    top: 107px;
    height: 26px;
    width: auto;
    transform: perspective(2000px) rotateZ(300deg) rotateX(40deg) rotateY(39deg)
      scale(0.8);
  }
}

#app {
  width: 100%;
  max-width: 100%;
  margin: 0;
  text-align: left;
  border: none;
  min-height: 100svh;
  display: block;
  box-sizing: border-box;
}

#center {
  display: flex;
  flex-direction: column;
  gap: 25px;
  place-content: center;
  place-items: center;
  flex-grow: 1;

  @media (max-width: 1024px) {
    padding: 32px 20px 24px;
    gap: 18px;
  }
}

#next-steps {
  display: flex;
  border-top: 1px solid var(--border);
  text-align: left;

  & > div {
    flex: 1 1 0;
    padding: 32px;
    @media (max-width: 1024px) {
      padding: 24px 20px;
    }
  }

  .icon {
    margin-bottom: 16px;
    width: 22px;
    height: 22px;
  }

  @media (max-width: 1024px) {
    flex-direction: column;
    text-align: center;
  }
}

#docs {
  border-right: 1px solid var(--border);

  @media (max-width: 1024px) {
    border-right: none;
    border-bottom: 1px solid var(--border);
  }
}

#next-steps ul {
  list-style: none;
  padding: 0;
  display: flex;
  gap: 8px;
  margin: 32px 0 0;

  .logo {
    height: 18px;
  }

  a {
    color: var(--text-h);
    font-size: 16px;
    border-radius: 6px;
    background: var(--social-bg);
    display: flex;
    padding: 6px 12px;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    transition: box-shadow 0.3s;

    &:hover {
      box-shadow: var(--shadow);
    }
    .button-icon {
      height: 18px;
      width: 18px;
    }
  }

  @media (max-width: 1024px) {
    margin-top: 20px;
    flex-wrap: wrap;
    justify-content: center;

    li {
      flex: 1 1 calc(50% - 8px);
    }

    a {
      width: 100%;
      justify-content: center;
      box-sizing: border-box;
    }
  }
}

#spacer {
  height: 88px;
  border-top: 1px solid var(--border);
  @media (max-width: 1024px) {
    height: 48px;
  }
}

.ticks {
  position: relative;
  width: 100%;

  &::before,
  &::after {
    content: '';
    position: absolute;
    top: -4.5px;
    border: 5px solid transparent;
  }

  &::before {
    left: 0;
    border-left-color: var(--border);
  }
  &::after {
    right: 0;
    border-right-color: var(--border);
  }
}

/* Sheets-like UI */

:root {
  --sheet-bg: #f8f9fa;
  --sheet-surface: #ffffff;
  --sheet-text: #202124;
  --sheet-muted: #5f6368;
  --sheet-border: #dadce0;
  --sheet-header: #f1f3f4;
  --sheet-blue: #1a73e8;
}

.app-shell {
  background: var(--sheet-bg);
  min-height: 100svh;
  color: var(--sheet-text);
  font: 14px/1.4 system-ui, -apple-system, 'Segoe UI', Roboto, Arial, sans-serif;
}

.sheet-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 16px;
}

.sheet-topbar {
  display: flex;
  gap: 12px;
  align-items: center;
  padding: 10px 12px;
  background: var(--sheet-surface);
  border: 1px solid var(--sheet-border);
  border-radius: 10px;
}

.sheet-topbar a {
  color: var(--sheet-text);
  text-decoration: none;
  padding: 6px 10px;
  border-radius: 8px;
}

.sheet-topbar a.router-link-active {
  background: rgba(26, 115, 232, 0.1);
  color: var(--sheet-blue);
}

.sheet-page {
  margin-top: 14px;
  background: var(--sheet-surface);
  border: 1px solid var(--sheet-border);
  border-radius: 10px;
  overflow: hidden;
}

.sheet-page-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12px;
  padding: 12px;
  border-bottom: 1px solid var(--sheet-border);
  background: var(--sheet-surface);
}

.sheet-page-header h1,
.sheet-page-header h2 {
  margin: 0;
  font-size: 16px;
  font-weight: 600;
  letter-spacing: 0;
}

.sheet-subtitle {
  color: var(--sheet-muted);
  font-size: 12px;
}

.sheet-actions {
  display: inline-flex;
  gap: 8px;
  align-items: center;
}

.sheet-body {
  padding: 12px;
}

.sheet-link {
  color: var(--sheet-blue);
  text-decoration: none;
}

.sheet-muted {
  color: var(--sheet-muted);
}

.sheet-btn {
  appearance: none;
  border: 1px solid var(--sheet-border);
  background: var(--sheet-surface);
  color: var(--sheet-text);
  border-radius: 8px;
  padding: 8px 10px;
  font: inherit;
  cursor: pointer;
}

.sheet-btn-primary {
  border-color: var(--sheet-blue);
  background: var(--sheet-blue);
  color: #fff;
}

.sheet-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.sheet-input,
.sheet-select,
.sheet-textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1px solid var(--sheet-border);
  border-radius: 8px;
  padding: 8px 10px;
  font: inherit;
  background: #fff;
  color: var(--sheet-text);
}

.sheet-textarea {
  resize: vertical;
}

.sheet-form {
  display: grid;
  gap: 10px;
}

.sheet-grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.sheet-table-wrap {
  overflow: auto;
  border: 1px solid var(--sheet-border);
  border-radius: 10px;
}

.sheet-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}

.sheet-table th {
  position: sticky;
  top: 0;
  background: var(--sheet-header);
  z-index: 2;
  text-align: left;
  font-weight: 600;
  color: var(--sheet-text);
  border-bottom: 1px solid var(--sheet-border);
  padding: 8px;
  white-space: nowrap;
}

.sheet-table td {
  border-bottom: 1px solid var(--sheet-border);
  padding: 8px;
  background: #fff;
  vertical-align: top;
}

.sheet-table tr:hover td {
  background: #f8fbff;
}

.sheet-table td.right,
.sheet-table th.right {
  text-align: right;
}

.sheet-sticky-col {
  position: sticky;
  left: 0;
  z-index: 1;
}

.sheet-sticky-col.sheet-th {
  z-index: 3;
}
